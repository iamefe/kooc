#!/usr/bin/env bash
# kooc вЂ” Agent launcher (OpenCode, Claude Code, ...)
# Picks agent в†’ connects to Kaggle Ollama в†’ picks model в†’ launches

# в”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[38;5;51m'
MAGENTA='\033[38;5;205m'
YELLOW='\033[38;5;220m'
GREEN='\033[38;5;82m'
RED='\033[38;5;196m'
GREY='\033[38;5;242m'

# в”Ђв”Ђ Agents в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
AGENTS=("Claude Code" "Opencode (direct)" "Opencode (Ollama)" "Hermes" "Ollama TUI")

# в”Ђв”Ђ Storage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
KOOC_DIR="$HOME/.kooc"
URLS_FILE="$KOOC_DIR/urls"
mkdir -p "$KOOC_DIR"

# в”Ђв”Ђ Load saved URLs (once) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SAVED_URLS=()
if [[ -f "$URLS_FILE" ]]; then
  while IFS= read -r url; do
    [[ -n "$url" ]] && SAVED_URLS+=("$url")
  done < "$URLS_FILE"
fi

# в”Ђв”Ђ URL selection + connection loop в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
while true; do
  clear
  echo ""
  echo ""

  echo ""
  echo -e "${BOLD}${CYAN}   в–€в–€в•—  в–€в–€в•— в–€в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в–€в•—${RESET}"
  echo -e "${BOLD}${CYAN}   в–€в–€в•‘ в–€в–€в•”в•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќ${RESET}"
  echo -e "${BOLD}${CYAN}   в–€в–€в–€в–€в–€в•”в•ќ в–€в–€в•‘   в–€в–€в•‘в–€в–€в•‘   в–€в–€в•‘в–€в–€в•‘     ${RESET}"
  echo -e "${BOLD}${CYAN}   в–€в–€в•”в•ђв–€в–€в•— в–€в–€в•‘   в–€в–€в•‘в–€в–€в•‘   в–€в–€в•‘в–€в–€в•‘     ${RESET}"
  echo -e "${BOLD}${CYAN}   в–€в–€в•‘  в–€в–€в•—в•љв–€в–€в–€в–€в–€в–€в•”в•ќв•љв–€в–€в–€в–€в–€в–€в•”в•ќв•љв–€в–€в–€в–€в–€в–€в•—${RESET}"
  echo -e "${BOLD}${CYAN}   в•љв•ђв•ќ  в•љв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ќ  в•љв•ђв•ђв•ђв•ђв•ђв•ќ  в•љв•ђв•ђв•ђв•ђв•ђв•ќ${RESET}"
  echo ""
  echo -e "${GREY}   Kaggle В· Ollama В· OpenCode / Claude${RESET}"
  echo ""
  echo -e "${GREY}   в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
  echo ""

  IS_NEW_URL=false

  if [[ ${#SAVED_URLS[@]} -gt 0 ]]; then
    CHOICE=$(printf '%s\n' \
      "[ + Enter new URL ]" \
      "[ Г— Delete a URL  ]" \
      "http://127.0.0.1:11434 (local)" \
      "${SAVED_URLS[@]}" | fzf \
      --prompt="   URL: " \
      --pointer="в–¶" \
      --highlight-line \
      --no-info \
      --no-sort \
      --height=$((${#SAVED_URLS[@]} + 8)) \
      --layout=reverse \
      --color="fg:#aaaaaa,fg+:#00d7ff,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#00d7ff" \
      --border=rounded \
      --margin=1,3)

    [[ -z "$CHOICE" ]] && exit 0

    if [[ "$CHOICE" == "[ + Enter new URL ]" ]]; then
      echo -e "   ${YELLOW}Kaggle URL:${RESET}"
      echo -ne "   ${YELLOW}в–¶ ${RESET}"
      read -r KAGGLE_URL
      IS_NEW_URL=true
    elif [[ "$CHOICE" == "http://127.0.0.1:11434 (local)" ]]; then
      KAGGLE_URL="http://127.0.0.1:11434"
    elif [[ "$CHOICE" == "[ Г— Delete a URL  ]" ]]; then
      DEL=$(printf '%s\n' "${SAVED_URLS[@]}" | fzf \
        --prompt="   Delete: " \
        --pointer="в–¶" \
        --highlight-line \
        --no-info \
        --no-sort \
        --height=$((${#SAVED_URLS[@]} + 4)) \
        --layout=reverse \
        --color="fg:#aaaaaa,fg+:#ff5555,bg+:#282a36,pointer:#ff5555,prompt:#ff5555,hl+:#ff5555" \
        --border=rounded \
        --margin=1,3)
      if [[ -n "$DEL" ]]; then
        grep -vxF "$DEL" "$URLS_FILE" > "$URLS_FILE.tmp"; mv "$URLS_FILE.tmp" "$URLS_FILE"
        echo ""
        grep -vxF "$DEL" "$URLS_FILE" > "$URLS_FILE.tmp" && mv "$URLS_FILE.tmp" "$URLS_FILE"
        SAVED_URLS=()
        if [[ -f "$URLS_FILE" ]]; then
          while IFS= read -r url; do
            [[ -n "$url" ]] && SAVED_URLS+=("$url")
          done < "$URLS_FILE"
        fi
        echo -e "   ${GREEN}вњ“ Deleted:${RESET} ${GREY}${DEL}${RESET}"
        echo ""
      fi
      continue
    else
      KAGGLE_URL="$CHOICE"
    fi
  else
    CHOICE=$(printf '%s\n' "http://127.0.0.1:11434 (local)" "[ + Enter new URL ]" | fzf \
      --prompt="   URL: " \
      --pointer="в–¶" \
      --highlight-line \
      --no-info \
      --no-sort \
      --height=6 \
      --layout=reverse \
      --color="fg:#aaaaaa,fg+:#00d7ff,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#00d7ff" \
      --border=rounded \
      --margin=1,3)

    if [[ -z "$CHOICE" ]]; then
      exit 0
    fi

    if [[ "$CHOICE" == "[ + Enter new URL ]" ]]; then
      echo -e "   ${YELLOW}Kaggle URL:${RESET}"
      echo -ne "   ${YELLOW}в–¶ ${RESET}"
      read -r KAGGLE_URL
      IS_NEW_URL=true
    else
      KAGGLE_URL="${CHOICE% (local)}"
    fi
  fi

  if [[ -z "$KAGGLE_URL" ]]; then
    echo -e "\n   ${RED}вњ— No URL provided. Exiting.${RESET}\n"
    exit 1
  fi

  KAGGLE_URL="${KAGGLE_URL%/}"

  echo ""
  echo -e "   ${GREY}Connecting to ${DIM}${KAGGLE_URL}${RESET}${GREY}...${RESET}"
  echo ""

  RAW=$(OLLAMA_HOST="$KAGGLE_URL" ollama list 2>&1)

  if echo "$RAW" | grep -qi "error\|refused\|could not\|failed"; then
    echo -e "   ${RED}вњ— Could not reach Ollama at ${KAGGLE_URL}${RESET}"
    echo -e "   ${GREY}Is your Kaggle session running?${RESET}"
    sleep 2
    continue
  fi

  break
done

# в”Ђв”Ђ Offer to save new URL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ "$IS_NEW_URL" == true ]]; then
  echo -ne "   ${YELLOW}Save this URL for next time? [y/N]: ${RESET}"
  read -r SAVE
  if [[ "$SAVE" =~ ^[Yy]$ ]]; then
    echo "$KAGGLE_URL" >> "$URLS_FILE"
    echo -e "   ${GREEN}вњ“ Saved${RESET}"
  fi
  echo ""
fi

# в”Ђв”Ђ Agent picker в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo ""
echo -e "   ${MAGENTA}${BOLD}Select Agent${RESET}  ${GREY}(в†‘в†“ to move, Enter to select)${RESET}"
echo -e "   ${GREY}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
echo ""

AGENT=$(printf '%s\n' "${AGENTS[@]}" | fzf \
  --prompt="   Agent: " \
  --pointer="в–¶" \
  --highlight-line \
  --no-info \
  --no-sort \
  --height=9 \
  --color="fg:#aaaaaa,fg+:#ff79c6,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#50fa7b" \
  --border=rounded \
  --margin=1,3)

if [[ -z "$AGENT" ]]; then
  echo -e "   ${RED}вњ— No agent selected.${RESET}\n"
  exit 1
fi

# в”Ђв”Ђ Model picker (only for agents that need it) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SELECTED_MODEL=""
NEEDS_MODEL=false
if [[ "$AGENT" == "Claude Code" || "$AGENT" == "Opencode (Ollama)" || "$AGENT" == "Ollama TUI" ]]; then
  NEEDS_MODEL=true

  # в”Ђв”Ђ Parse models в”Ђв”Ђ
  MODELS=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && MODELS+=("$line")
  done < <(echo "$RAW" | tail -n +2 | awk '{print $1}' | grep -v '^$')

  if [[ ${#MODELS[@]} -eq 0 ]]; then
    echo -e "   ${RED}вњ— No models found.${RESET}\n"
    exit 1
  fi

  echo -e "   ${CYAN}${BOLD}Available Models${RESET}  ${GREY}(в†‘в†“ to move, Enter to select)${RESET}"
  echo -e "   ${GREY}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"

  SELECTED_MODEL=$(printf '%s\n' "${MODELS[@]}" | fzf \
    --prompt="   Model: " \
    --pointer="в–¶" \
    --highlight-line \
    --no-info \
    --no-sort \
    --height=8 \
    --color="fg:#aaaaaa,fg+:#ff79c6,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#50fa7b" \
    --border=rounded \
    --margin=0,3)

  if [[ -z "$SELECTED_MODEL" ]]; then
    echo -e "   ${RED}вњ— No model selected.${RESET}\n"
    exit 1
  fi
fi

# в”Ђв”Ђ Summary в”Ђв”Ђ
echo ""
echo -e "   ${GREY}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
echo ""
if [[ -n "$SELECTED_MODEL" ]]; then
  echo -e "   ${GREEN}${BOLD}вњ“ ${AGENT}${RESET}  +  ${GREEN}${BOLD}вњ“ ${SELECTED_MODEL}${RESET}"
else
  echo -e "   ${GREEN}${BOLD}вњ“ ${AGENT}${RESET}"
fi
echo ""

# в”Ђв”Ђ Thinking toggle for Ollama TUI в”Ђв”Ђ
THINK=true
if [[ "$AGENT" == "Ollama TUI" ]]; then
  echo -e "   ${MAGENTA}${BOLD}Thinking Mode${RESET}  ${GREY}(в†‘в†“ to move, Enter to select)${RESET}"
  echo -e "   ${GREY}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
  echo ""

  THINK_CHOICE=$(printf '%s\n' "Enable thinking" "Disable thinking" | fzf \
    --prompt="   Thinking: " \
    --pointer="в–¶" \
    --highlight-line \
    --no-info \
    --no-sort \
    --height=8 \
    --color="fg:#aaaaaa,fg+:#ff79c6,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#50fa7b" \
    --border=rounded \
    --margin=1,3)

  if [[ "$THINK_CHOICE" == "Disable thinking" ]]; then
    THINK=false
  fi
fi

# в”Ђв”Ђ Validate Opencode config в”Ђв”Ђ
check_opencode_config() {
  local config="$HOME/.config/opencode/opencode.json"

  if [[ ! -f "$config" ]]; then
    echo -e "   ${RED}вњ— opencode.json not found${RESET}"
    echo -e "   ${GREY}See the opencode.json sample at https://github.com/iamefe/kooc for the format we expect${RESET}"
    return 1
  fi

  local base_url
  base_url=$(sed '/^ *\/\//d' "$config" | jq -r '.provider.ollama.options.baseURL // empty' 2>/dev/null)

  if [[ -z "$base_url" ]]; then
    echo -e "   ${RED}вњ— baseURL not found in opencode config${RESET}"
    echo -e "   ${GREY}Expected ${CYAN}\"baseURL\": \"\${OLLAMA_HOST}/v1\"${RESET}"
    echo -e "   ${GREY}See the opencode.json sample at https://github.com/iamefe/kooc for the format we expect${RESET}"
    return 1
  fi

  # Accept either the literal placeholder or a resolved Ollama URL
  if [[ "$base_url" != *'${OLLAMA_HOST}'* ]] && [[ "$base_url" != *"${OLLAMA_HOST}"* ]]; then
    echo -e "   ${RED}вњ— baseURL does not point to your Ollama instance${RESET}"
    echo -e "   ${GREY}Found:${RESET} ${GREY}${base_url}${RESET}"
    echo -e "   ${GREY}Expected:${RESET} ${CYAN}\${OLLAMA_HOST}/v1${RESET}"
    echo -e "   ${GREY}See the opencode.json sample at https://github.com/iamefe/kooc for the format we expect${RESET}"
    return 1
  fi

  return 0
}

# в”Ђв”Ђ Launch в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
OLLAMA_HOST="$KAGGLE_URL"
export OLLAMA_HOST

case "$AGENT" in
  "Opencode (Ollama)")
    echo -e "   ${GREY}Launching Opencode via Ollama...${RESET}"
    echo ""
    ollama launch opencode --model "$SELECTED_MODEL"
    ;;
  "Opencode (direct)")
    if ! check_opencode_config; then
      exit 1
    fi
    echo -e "   ${GREY}Launching Opencode...${RESET}"
    echo ""
    opencode
    ;;
  "Hermes")
    echo -e "   ${GREY}Launching Hermes...${RESET}"
    echo ""
    hermes
    ;;
  "Claude Code")
    echo -e "   ${GREY}Launching Claude Code...${RESET}"
    echo ""
    clear
    echo ""
    echo ""
    ollama launch claude --model "$SELECTED_MODEL"
    ;;
  "Ollama TUI")
    echo -e "   ${GREY}Launching Ollama TUI with thinking=${THINK}...${RESET}"
    echo ""
    ollama run "$SELECTED_MODEL" --think=$THINK
    ;;
esac
