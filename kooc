#!/usr/bin/env bash
# kooc вҖ” Kaggle OpenCode launcher

# в”Җв”Җ Colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[38;5;51m'
MAGENTA='\033[38;5;205m'
YELLOW='\033[38;5;220m'
GREEN='\033[38;5;82m'
RED='\033[38;5;196m'
GREY='\033[38;5;242m'

clear

# в”Җв”Җ Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "${BOLD}\033[38;5;51m   в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${RESET}"
echo -e "${BOLD}\033[38;5;45m   в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ${RESET}"
echo -e "${BOLD}\033[38;5;99m   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     ${RESET}"
echo -e "${BOLD}\033[38;5;135m   в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     ${RESET}"
echo -e "${BOLD}\033[38;5;171m   в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${RESET}"
echo -e "${BOLD}\033[38;5;205m   в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ${RESET}"
echo -e "${GREY}   Kaggle В· Ollama В· OpenCode${RESET}"
echo ""
echo -e "${GREY}   в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RESET}"
echo ""

# в”Җв”Җ URL input в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
DEFAULT_URL="${KAGGLE_URL:-}"

if [[ -n "$DEFAULT_URL" ]]; then
  echo -e "   ${YELLOW}Kaggle URL ${GREY}(Enter to use: ${DIM}${DEFAULT_URL}${RESET}${GREY})${RESET}"
  echo -ne "   ${YELLOW}в–¶ ${RESET}"
  read -r INPUT_URL
  KAGGLE_URL="${INPUT_URL:-$DEFAULT_URL}"
else
  echo -e "   ${YELLOW}Kaggle URL:${RESET}"
  echo -ne "   ${YELLOW}в–¶ ${RESET}"
  read -r KAGGLE_URL
fi

if [[ -z "$KAGGLE_URL" ]]; then
  echo -e "\n   ${RED}вң— No URL provided. Exiting.${RESET}\n"
  exit 1
fi

KAGGLE_URL="${KAGGLE_URL%/}"

echo ""
echo -e "   ${GREY}Connecting to ${DIM}${KAGGLE_URL}${RESET}${GREY}...${RESET}"
echo ""

# в”Җв”Җ Fetch models в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RAW=$(OLLAMA_HOST="$KAGGLE_URL" ollama list 2>&1)

if echo "$RAW" | grep -qi "error\|refused\|could not\|failed"; then
  echo -e "   ${RED}вң— Could not reach Ollama at ${KAGGLE_URL}${RESET}"
  echo -e "   ${GREY}Is your Kaggle session running?${RESET}\n"
  exit 1
fi

MODELS=()
while IFS= read -r line; do
  [[ -n "$line" ]] && MODELS+=("$line")
done < <(echo "$RAW" | tail -n +2 | awk '{print $1}' | grep -v '^$')

if [[ ${#MODELS[@]} -eq 0 ]]; then
  echo -e "   ${RED}вң— No models found.${RESET}\n"
  exit 1
fi

# в”Җв”Җ Display & select в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "   ${CYAN}${BOLD}Available Models${RESET}  ${GREY}(вҶ‘вҶ“ to move, Enter to select)${RESET}"
echo -e "   ${GREY}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RESET}"
echo ""

SELECTED=$(printf '%s\n' "${MODELS[@]}" | fzf \
  --prompt="   Model: " \
  --pointer="в–¶" \
  --highlight-line \
  --no-info \
  --no-sort \
  --height=$((${#MODELS[@]} + 4)) \
  --color="fg:#aaaaaa,fg+:#ff79c6,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#50fa7b" \
  --border=rounded \
  --margin=1,3)

if [[ -z "$SELECTED" ]]; then
  echo -e "   ${RED}вң— No model selected.${RESET}\n"
  exit 1
fi

echo ""
echo -e "   ${GREY}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RESET}"
echo ""
echo -e "   ${GREEN}${BOLD}вң“ ${SELECTED}${RESET}"
echo -e "   ${GREY}Launching OpenCode...${RESET}"
echo ""

# в”Җв”Җ Launch в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
OLLAMA_HOST="$KAGGLE_URL" ollama launch opencode --model "$SELECTED"
