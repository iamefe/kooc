#!/usr/bin/env bash
# kooc — Agent launcher (OpenCode, Claude Code, ...)
# Picks agent → connects to Kaggle Ollama → picks model → launches

# ── Colors ───────────────────────────────────────────────────────────────────────
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[38;5;51m'
MAGENTA='\033[38;5;205m'
YELLOW='\033[38;5;220m'
GREEN='\033[38;5;82m'
RED='\033[38;5;196m'
GREY='\033[38;5;242m'

# ── Agents ─────────────────────────────────────────────────────────────────────
AGENTS=("Claude Code" "OpenCode" "Ollama TUI")

# ── Storage ───────────────────────────────────────────────────────────────────
KOOC_DIR="$HOME/.kooc"
URLS_FILE="$KOOC_DIR/urls"
mkdir -p "$KOOC_DIR"

# ── Load saved URLs (once) ────────────────────────────────────────────────────
SAVED_URLS=()
if [[ -f "$URLS_FILE" ]]; then
  while IFS= read -r url; do
    [[ -n "$url" ]] && SAVED_URLS+=("$url")
  done < "$URLS_FILE"
fi

# ── URL selection + connection loop ───────────────────────────────────────────
while true; do
  clear
  echo ""
  echo ""

  echo ""
  echo -e "${BOLD}${CYAN}   ██╗  ██╗ ██████╗  ██████╗  ██████╗${RESET}"
  echo -e "${BOLD}${CYAN}   ██║ ██╔╝██╔═══██╗██╔═══██╗██╔════╝${RESET}"
  echo -e "${BOLD}${CYAN}   █████╔╝ ██║   ██║██║   ██║██║     ${RESET}"
  echo -e "${BOLD}${CYAN}   ██╔═██╗ ██║   ██║██║   ██║██║     ${RESET}"
  echo -e "${BOLD}${CYAN}   ██║  ██╗╚██████╔╝╚██████╔╝╚██████╗${RESET}"
  echo -e "${BOLD}${CYAN}   ╚═╝  ╚═╝ ╚═════╝  ╚═════╝  ╚═════╝${RESET}"
  echo ""
  echo -e "${GREY}   Kaggle · Ollama · OpenCode / Claude${RESET}"
  echo ""
  echo -e "${GREY}   ────────────────────────────────────────${RESET}"
  echo ""

  IS_NEW_URL=false

  if [[ ${#SAVED_URLS[@]} -gt 0 ]]; then
    CHOICE=$(printf '%s\n' \
      "[ + Enter new URL ]" \
      "[ × Delete a URL  ]" \
      "${SAVED_URLS[@]}" | fzf \
      --prompt="   URL: " \
      --pointer="▶" \
      --highlight-line \
      --no-info \
      --no-sort \
      --height=$((${#SAVED_URLS[@]} + 8)) \
      --layout=reverse \
      --color="fg:#aaaaaa,fg+:#00d7ff,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#00d7ff" \
      --border=rounded \
      --margin=1,3)

    [[ -z "$CHOICE" ]] && exit 0

    if [[ "$CHOICE" == "[ + Enter new URL ]" ]]; then
      echo -e "   ${YELLOW}Kaggle URL:${RESET}"
      echo -ne "   ${YELLOW}▶ ${RESET}"
      read -r KAGGLE_URL
      IS_NEW_URL=true
    elif [[ "$CHOICE" == "[ × Delete a URL  ]" ]]; then
      DEL=$(printf '%s\n' "${SAVED_URLS[@]}" | fzf \
        --prompt="   Delete: " \
        --pointer="▶" \
        --highlight-line \
        --no-info \
        --no-sort \
        --height=$((${#SAVED_URLS[@]} + 4)) \
        --layout=reverse \
        --color="fg:#aaaaaa,fg+:#ff5555,bg+:#282a36,pointer:#ff5555,prompt:#ff5555,hl+:#ff5555" \
        --border=rounded \
        --margin=1,3)
      if [[ -n "$DEL" ]]; then
        grep -vxF "$DEL" "$URLS_FILE" > "$URLS_FILE.tmp"; mv "$URLS_FILE.tmp" "$URLS_FILE"
        echo ""
        grep -vxF "$DEL" "$URLS_FILE" > "$URLS_FILE.tmp" && mv "$URLS_FILE.tmp" "$URLS_FILE"
        SAVED_URLS=()
        if [[ -f "$URLS_FILE" ]]; then
          while IFS= read -r url; do
            [[ -n "$url" ]] && SAVED_URLS+=("$url")
          done < "$URLS_FILE"
        fi
        echo -e "   ${GREEN}✓ Deleted:${RESET} ${GREY}${DEL}${RESET}"
        echo ""
      fi
      continue
    else
      KAGGLE_URL="$CHOICE"
    fi
  else
    echo -e "   ${YELLOW}Kaggle URL:${RESET}"
    echo -ne "   ${YELLOW}▶ ${RESET}"
    read -r KAGGLE_URL
    IS_NEW_URL=true
  fi

  if [[ -z "$KAGGLE_URL" ]]; then
    echo -e "\n   ${RED}✗ No URL provided. Exiting.${RESET}\n"
    exit 1
  fi

  KAGGLE_URL="${KAGGLE_URL%/}"

  echo ""
  echo -e "   ${GREY}Connecting to ${DIM}${KAGGLE_URL}${RESET}${GREY}...${RESET}"
  echo ""

  RAW=$(OLLAMA_HOST="$KAGGLE_URL" ollama list 2>&1)

  if echo "$RAW" | grep -qi "error\|refused\|could not\|failed"; then
    echo -e "   ${RED}✗ Could not reach Ollama at ${KAGGLE_URL}${RESET}"
    echo -e "   ${GREY}Is your Kaggle session running?${RESET}"
    sleep 2
    continue
  fi

  break
done

# ── Offer to save new URL ─────────────────────────────────────────────────────
if [[ "$IS_NEW_URL" == true ]]; then
  echo -ne "   ${YELLOW}Save this URL for next time? [y/N]: ${RESET}"
  read -r SAVE
  if [[ "$SAVE" =~ ^[Yy]$ ]]; then
    echo "$KAGGLE_URL" >> "$URLS_FILE"
    echo -e "   ${GREEN}✓ Saved${RESET}"
  fi
  echo ""
fi

# ── Parse models ──────────────────────────────────────────────────────────────
MODELS=()
while IFS= read -r line; do
  [[ -n "$line" ]] && MODELS+=("$line")
done < <(echo "$RAW" | tail -n +2 | awk '{print $1}' | grep -v '^$')

if [[ ${#MODELS[@]} -eq 0 ]]; then
  echo -e "   ${RED}✗ No models found.${RESET}\n"
  exit 1
fi

# ── Display & select model ──────────────────────────────────────────────────────
echo -e "   ${CYAN}${BOLD}Available Models${RESET}  ${GREY}(↑↓ to move, Enter to select)${RESET}"
echo -e "   ${GREY}────────────────────────────────────────${RESET}"

SELECTED_MODEL=$(printf '%s\n' "${MODELS[@]}" | fzf \
  --prompt="   Model: " \
  --pointer="▶" \
  --highlight-line \
  --no-info \
  --no-sort \
  --height=8 \
  --color="fg:#aaaaaa,fg+:#ff79c6,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#50fa7b" \
  --border=rounded \
  --margin=0,3)

if [[ -z "$SELECTED_MODEL" ]]; then
  echo -e "   ${RED}✗ No model selected.${RESET}\n"
  exit 1
fi

# ── Agent picker ───────────────────────────────────────────────────────────────
echo ""
echo -e "   ${MAGENTA}${BOLD}Select Agent${RESET}  ${GREY}(↑↓ to move, Enter to select)${RESET}"
echo -e "   ${GREY}────────────────────────────────────────${RESET}"
echo ""

AGENT=$(printf '%s\n' "${AGENTS[@]}" | fzf \
  --prompt="   Agent: " \
  --pointer="▶" \
  --highlight-line \
  --no-info \
  --no-sort \
  --height=9 \
  --color="fg:#aaaaaa,fg+:#ff79c6,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#50fa7b" \
  --border=rounded \
  --margin=1,3)

if [[ -z "$AGENT" ]]; then
  echo -e "   ${RED}✗ No agent selected.${RESET}\n"
  exit 1
fi

echo ""
echo -e "   ${GREY}─────────────────────────────────────${RESET}"
echo ""
echo -e "   ${GREEN}${BOLD}✓ ${AGENT}${RESET}  +  ${GREEN}${BOLD}✓ ${SELECTED_MODEL}${RESET}"
echo ""

# ── Thinking toggle for Ollama TUI ──
THINK=true
if [[ "$AGENT" == "Ollama TUI" ]]; then
  echo -e "   ${MAGENTA}${BOLD}Thinking Mode${RESET}  ${GREY}(↑↓ to move, Enter to select)${RESET}"
  echo -e "   ${GREY}─────────────────────────────────────────────${RESET}"
  echo ""

  THINK=$(printf '%s\n' "Enable thinking" "Disable thinking" | fzf \
    --prompt="   Thinking: " \
    --pointer="▶" \
    --highlight-line \
    --no-info \
    --no-sort \
    --height=8 \
    --color="fg:#aaaaaa,fg+:#ff79c6,bg+:#282a36,pointer:#f8f8f2,prompt:#f1fa8c,hl+:#50fa7b" \
    --border=rounded \
    --margin=1,3)

  if [[ "$THINK" == "Disable thinking" ]]; then
    THINK=false
  fi
fi

# ── Launch ─────────────────────────────────────────────────────────────────
OLLAMA_HOST="$KAGGLE_URL"
export OLLAMA_HOST

case "$AGENT" in
  "OpenCode")
    echo -e "   ${GREY}Launching OpenCode...${RESET}"
    echo ""
    ollama launch opencode --model "$SELECTED_MODEL"
    ;;
  "Claude Code")
    echo -e "   ${GREY}Launching Claude Code...${RESET}"
    echo ""
    clear
    echo ""
    echo ""
    ollama launch claude --model "$SELECTED_MODEL"
    ;;
  "Ollama TUI")
    echo -e "   ${GREY}Launching Ollama TUI with thinking=${THINK}...${RESET}"
    echo ""
    ollama run "$SELECTED_MODEL" --think=$THINK
    ;;
esac
